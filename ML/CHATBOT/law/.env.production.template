# =====================================================
# NyaySetu RAG Backend - Environment Template
# =====================================================
# Copy this file to .env in the same folder and fill in the values.
# =====================================================

# Google Gemini API key - used for both the LLM and the embeddings.
# Get a free key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_gemini_api_key

# Port the Flask backend listens on (must match the Vite proxy in frontend/vite.config.js).
PORT=5001

# Comma-separated list of frontend origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:5100,http://127.0.0.1:5100

# Optional: stable secret for Flask sessions. If unset, a random one is generated on each start.
FLASK_SECRET_KEY=change_me_to_a_random_long_string
