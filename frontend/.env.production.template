# =====================================================
# LegalNexus Frontend - Production Environment Template
# =====================================================
# Copy this file to .env.production and fill in values
# 
# For Vercel deployment:
# 1. Go to your project settings on Vercel
# 2. Add these as Environment Variables
# =====================================================

# Backend API (Your Render backend URL)
VITE_API_URL=https://legalnexus-backend.onrender.com

# Chatbot Service (Your Render chatbot URL)
VITE_CHATBOT_URL=https://legalnexus-chatbot.onrender.com

# Document Analyzer Service (Your Render doc analyzer URL)  
VITE_DOC_ANALYZER_URL=https://legalnexus-docanalyzer.onrender.com

# Google Maps API Key (Get from Google Cloud Console)
VITE_MAP_API_KEY=your_google_maps_api_key

# Firebase Configuration (for Firestore only - auth is now JWT)
VITE_API_KEY=your_firebase_api_key
VITE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_PROJECT_ID=your_firebase_project_id
VITE_STORAGE_BUCKET=your_project.appspot.com
VITE_MESSAGING_SENDER_ID=your_sender_id
VITE_APP_ID=your_app_id
